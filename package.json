{
  "name": "pi-agent-kit-workspace",
  "version": "1.0.0",
  "description": "Reusable skills and extensions for Pi coding agent",
  "type": "module",
  "private": true,
  "workspaces": [
    "extensions/*"
  ],
  "keywords": [
    "pi-package",
    "ai-agent",
    "coding-assistant",
    "skills",
    "extensions"
  ],
  "author": "aldoborrero",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aldoborrero/pi-agent-kit.git"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "codex-plugin-cc": "github:openai/codex-plugin-cc",
    "gray-matter": "^4.0.3",
    "pi-lsp-extension": "github:samfoy/pi-lsp-extension",
    "pi-mcp-adapter": "github:nicobailon/pi-mcp-adapter"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "latest",
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@sinclair/typebox": "latest"
  },
  "pi": {
    "themes": [
      "themes"
    ],
    "skills": [
      "skills"
    ],
    "agents": [
      "agents"
    ],
    "prompts": [
      "prompts"
    ],
    "extensions": [
      "extensions/pi-agent-kit"
    ]
  }
}
